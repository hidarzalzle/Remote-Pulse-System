<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <!--
    Some developer machines have global NuGet fallback folders configured (e.g., vendor offline caches).
    Those paths do not exist inside Linux containers and can break `dotnet restore`.
    This repo-level NuGet.Config ensures deterministic restores in Docker/CI.
  -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
